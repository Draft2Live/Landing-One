{
  "name": "draft2live-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:uk": "NEXT_PUBLIC_LOCALE=uk next build",
    "build:en": "NEXT_PUBLIC_LOCALE=en next build",
    "build:ru": "NEXT_PUBLIC_LOCALE=ru next build",
    "build:pl": "NEXT_PUBLIC_LOCALE=pl next build",
    "build:all": "npm run build:uk && npm run build:en && npm run build:ru && npm run build:pl",
    "dist:all": "bash -c 'rm -rf dist && for loc in uk en ru pl; do NEXT_PUBLIC_LOCALE=$loc npx next build && mkdir -p dist/$loc && cp -r out/* dist/$loc/; done'",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "framer-motion": "^12.38.0",
    "gsap": "^3.14.2",
    "next": "16.2.2",
    "next-intl": "^4.9.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
